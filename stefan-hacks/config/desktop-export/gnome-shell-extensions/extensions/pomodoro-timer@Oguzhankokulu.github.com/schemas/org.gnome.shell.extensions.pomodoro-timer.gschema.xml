<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="pomodoro-timer">
  <schema id="org.gnome.shell.extensions.pomodoro-timer" path="/org/gnome/shell/extensions/pomodoro-timer/">
    
    <!-- Timer Durations (in seconds) -->
    <key name="work-duration" type="i">
      <default>1500</default>
      <summary>Work duration in seconds</summary>
    </key>
    
    <key name="short-break-duration" type="i">
      <default>300</default>
      <summary>Short break duration in seconds</summary>
    </key>
    
    <key name="long-break-duration" type="i">
      <default>900</default>
      <summary>Long break duration in seconds</summary>
    </key>
    
    <!-- Interval Settings -->
    <key name="intervals-per-set" type="i">
      <default>4</default>
      <summary>Work intervals per set</summary>
    </key>
    
    <!-- Auto-start Settings -->
    <key name="auto-start-breaks" type="b">
      <default>false</default>
      <summary>Auto-start breaks</summary>
    </key>
    
    <key name="auto-start-work" type="b">
      <default>false</default>
      <summary>Auto-start work</summary>
    </key>
    
    <!-- Sound Settings -->
    <key name="sound-enabled" type="b">
      <default>true</default>
      <summary>Enable sounds</summary>
    </key>
    
    <key name="tick-sound-enabled" type="b">
      <default>false</default>
      <summary>Enable tick sound</summary>
    </key>
    
    <key name="event-sound-volume" type="d">
      <default>0.5</default>
      <summary>Event sound volume level (0.0 to 1.0)</summary>
    </key>
    
    <key name="tick-sound-volume" type="d">
      <default>0.5</default>
      <summary>Tick sound volume level (0.0 to 1.0)</summary>
    </key>
    
    <!-- Theme Settings -->
    <key name="use-system-theme" type="b">
      <default>false</default>
      <summary>Use system theme colors</summary>
      <description>Blend with GNOME theme instead of using hardcoded colors</description>
    </key>

    <!-- Panel Display Settings -->
    <key name="show-icon" type="b">
      <default>true</default>
      <summary>Show icon in panel</summary>
    </key>
    
    <key name="show-timer-always" type="b">
      <default>false</default>
      <summary>Always show timer in panel</summary>
    </key>
    
    <!-- Suspend Inhibitor Settings -->
    <key name="suspend-inhibitor-enabled" type="b">
      <default>true</default>
      <summary>Disable auto-suspend during pomodoro</summary>
    </key>
    
    <!-- Focus Mode Settings -->
    <key name="focus-wallpaper-enabled" type="b">
      <default>false</default>
      <summary>Change wallpaper during work</summary>
      <description>Switch to a focus wallpaper during work sessions</description>
    </key>
    
    <key name="focus-wallpaper-option" type="s">
      <default>'dark-academia'</default>
      <summary>Focus wallpaper option</summary>
      <description>Which wallpaper to use: anime, cloudscape, dark-academia, forest, minecraft, or custom</description>
    </key>
    
    <key name="focus-custom-wallpaper" type="s">
      <default>''</default>
      <summary>Custom focus wallpaper path</summary>
      <description>File path for custom focus wallpaper</description>
    </key>
    
    <key name="focus-dnd-enabled" type="b">
      <default>true</default>
      <summary>Enable Do Not Disturb during focus</summary>
      <description>Suppress notification banners during work sessions</description>
    </key>
    
    <key name="focus-mute-sounds" type="b">
      <default>true</default>
      <summary>Mute notification sounds during focus</summary>
      <description>Disable system event sounds during work sessions</description>
    </key>

    <key name="notify-enabled" type="b">
      <default>true</default>
      <summary>Show pomodoro notifications</summary>
      <description>Show system notifications for session events</description>
    </key>

    <key name="auto-complete-tasks" type="b">
      <default>false</default>
      <summary>Auto-complete tasks</summary>
      <description>Automatically complete non-repeated tasks when estimated pomodoros are reached</description>
    </key>

    <!-- Away from Desk Detection -->
    <key name="idle-detection-enabled" type="b">
      <default>false</default>
      <summary>Enable away from desk detection</summary>
      <description>Detect when user is away and handle idle time</description>
    </key>

    <key name="idle-detection-mode" type="s">
      <default>'auto-pause'</default>
      <summary>Idle detection mode</summary>
      <description>How to handle idle time: auto-pause or ask-on-return</description>
    </key>

    <key name="idle-threshold" type="i">
      <default>120</default>
      <summary>Idle threshold in seconds</summary>
      <description>Seconds of inactivity before considering user away</description>
    </key>
    
    <!-- Focus Mode Crash Recovery (internal) -->
    <key name="focus-saved-wallpaper-uri" type="s">
      <default>''</default>
      <summary>Saved wallpaper URI before focus mode (internal)</summary>
    </key>

    <key name="focus-saved-wallpaper-uri-dark" type="s">
      <default>''</default>
      <summary>Saved dark wallpaper URI before focus mode (internal)</summary>
    </key>

    <key name="focus-saved-show-banners" type="s">
      <default>''</default>
      <summary>Saved show-banners state before focus mode (internal)</summary>
    </key>

    <key name="focus-saved-event-sounds" type="s">
      <default>''</default>
      <summary>Saved event-sounds state before focus mode (internal)</summary>
    </key>

    <!-- Keybindings -->
    <key name="keybinding-toggle" type="as">
      <default>[]</default>
      <summary>Start/Pause timer</summary>
    </key>

    <key name="keybinding-skip" type="as">
      <default>[]</default>
      <summary>Skip current interval</summary>
    </key>

    <key name="keybinding-reset" type="as">
      <default>[]</default>
      <summary>Reset current interval</summary>
    </key>

    <key name="keybinding-reset-all" type="as">
      <default>[]</default>
      <summary>Reset all sessions</summary>
    </key>

    <!-- Session State (internal, for persistence across screen lock) -->
    <key name="session-state" type="s">
      <default>''</default>
      <summary>Current timer state (internal)</summary>
    </key>
    
    <key name="session-interval-type" type="s">
      <default>''</default>
      <summary>Current interval type (internal)</summary>
    </key>
    
    <key name="session-remaining-time" type="i">
      <default>-1</default>
      <summary>Remaining time in seconds (internal)</summary>
    </key>
    
    <key name="session-completed-intervals" type="i">
      <default>0</default>
      <summary>Completed work intervals (internal)</summary>
    </key>
    
    <key name="session-started" type="b">
      <default>false</default>
      <summary>Whether session has been started (internal)</summary>
    </key>
    <key name="current-task-id" type="s">
      <default>''</default>
      <summary>Current task ID</summary>
      <description>ID of the currently selected task for session tracking</description>
    </key>
    
  </schema>
</schemalist>